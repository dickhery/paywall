[
  {
    "match": "**/*",
    "security_policy": "standard",
    "headers": {
      "Permissions-Policy": "clipboard-write=(self)"
    }
    // Uncomment to disable the warning about using the standard policy:
    // "disable_security_policy_warning": true,
    // Uncomment to redirect raw.icp0.io to icp0.io:
    // "allow_raw_access": false
  },
  {
    "match": "index.html",
    "headers": {
      "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://thowo-iqaaa-aaaab-ac3wa-cai.icp0.io; connect-src 'self' http://localhost:* https://icp0.io https://*.icp0.io https://icp-api.io https://thowo-iqaaa-aaaab-ac3wa-cai.icp0.io; img-src 'self' data: https://thowo-iqaaa-aaaab-ac3wa-cai.icp0.io; style-src * 'unsafe-inline'; style-src-elem * 'unsafe-inline'; font-src *; frame-src 'self' https://thowo-iqaaa-aaaab-ac3wa-cai.icp0.io; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests;"
    }
  },
  {
    "match": "**/*.js",
    "headers": {
      "Access-Control-Allow-Origin": "*",
      "Access-Control-Allow-Methods": "GET, OPTIONS",
      "Access-Control-Allow-Headers": "Origin, X-Requested-With, Content-Type, Accept",
      "Cache-Control": "public, max-age=3600"
    }
  },
  {
    "match": "paywall.js",
    "headers": {
      "Access-Control-Allow-Origin": "*",
      "Access-Control-Allow-Methods": "GET, OPTIONS",
      "Access-Control-Allow-Headers": "Origin, X-Requested-With, Content-Type, Accept",
      "Cache-Control": "no-cache, no-store, max-age=0, must-revalidate"
    }
  }
]
